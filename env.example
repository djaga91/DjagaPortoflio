# API Backend URL (appels directs depuis le front)
# - Vide "" : requêtes vers même origine (ex. localhost:3001) → proxy Vite redirige /api vers le backend
# - Défini : ex. http://localhost:8888 → requêtes directes vers le backend (pas de proxy)
VITE_API_URL=http://localhost:8888

# Cible du proxy Vite (uniquement si VITE_API_URL est vide)
# En dev local sans Docker : VITE_PROXY_TARGET=http://localhost:8888 (backend sur 8888)
# En Docker : laisser vide → target = http://backend:8000
# VITE_PROXY_TARGET=http://localhost:8888

# App Environment
VITE_ENVIRONMENT=development

# ======================
# GlitchTip (Error Tracking - compatible Sentry SDK)
# ======================
# Variable nommée SENTRY_DSN pour compatibilité avec le SDK Sentry
# Activé uniquement en production (npm run build && npm run preview)
# VITE_SENTRY_DSN=https://xxx@app.glitchtip.com/xxx
